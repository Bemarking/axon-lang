# Dockerfile para axon-enterprise (Python sidecar)
# Python 3.12 slim con Starlette + uvicorn

FROM python:3.12-slim-bookworm

WORKDIR /app

# Crear usuario sin privilegios para ejecutar la aplicación
RUN useradd -r -s /bin/false axon

# Instalar dependencias del sistema necesarias
# ca-certificates para validación de certificados TLS
# curl para health checks
RUN apt-get update && apt-get install -y \
    ca-certificates \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Copiar archivos de configuración del proyecto
COPY pyproject.toml MANIFEST.in README.md LICENSE ./

# Copiar el código fuente del paquete axon
COPY axon/ axon/

# Instalar el paquete en modo editable con extras necesarios
# server: Starlette + uvicorn
# anthropic, openai, gemini: backends LLM
# postgresql: SQLAlchemy + asyncpg
# redis: soporte de Redis para caché/sesiones
RUN pip install --no-cache-dir -e ".[server,anthropic,openai,gemini,postgresql,redis]"

# Cambiar usuario a axon (sin privilegios)
USER axon

# Exponer el puerto del sidecar enterprise
EXPOSE 8080

# Health check — verifica que el servidor está listo
# startPeriod=20s: espera antes de empezar los checks (más corto que Rust)
# interval=30s: check cada 30 segundos
# timeout=10s: timeout de 10s por check
# retries=3: marcar como unhealthy después de 3 fallos
HEALTHCHECK --interval=30s --timeout=10s --start-period=20s --retries=3 \
    CMD curl -f http://localhost:8080/v1/health || exit 1

# Variables de entorno para configuración
ENV AXON_HOST=0.0.0.0
ENV AXON_PORT=8080
ENV AXON_SERVER_URL=http://localhost:8420

# Entrypoint: ejecutar el comando `axon serve`
# Este comando está definido en axon/cli/serve_cmd.py
# Inicia uvicorn en 0.0.0.0:8080 con mode enterprise
ENTRYPOINT ["python", "-m", "axon.cli", "serve"]
CMD ["--host", "0.0.0.0", "--port", "8080"]
