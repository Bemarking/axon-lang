{
  "description": "Fase 32.c body schema validation cross-stack drift corpus. Each entry pairs a `type T { … }` declaration set with a JSON body and asserts both stacks produce the SAME (expected_type, field_path, expected, got) tuple — pass when `expected_validation` is null, fail otherwise. The `hint` field is intentionally excluded from byte-identical assertion since prose formatting can tolerably drift across stacks; the structured triple is the locked invariant.",
  "d_letter_anchor": "D4 + D11",
  "entries": [
    {
      "name": "free_form_no_declaration_passes",
      "description": "D9 backwards-compat: empty body_type accepts anything",
      "type_declarations": [],
      "body_type": "",
      "body": {"any": "shape", "the": ["client", "sends"]},
      "expected_validation": null
    },
    {
      "name": "primitive_string_accepts_string",
      "type_declarations": [],
      "body_type": "String",
      "body": "hello",
      "expected_validation": null
    },
    {
      "name": "primitive_string_rejects_number",
      "type_declarations": [],
      "body_type": "String",
      "body": 42,
      "expected_validation": {
        "expected_type": "String",
        "field_path": "",
        "expected": "String",
        "got": "integer"
      }
    },
    {
      "name": "primitive_integer_accepts_integer",
      "type_declarations": [],
      "body_type": "Integer",
      "body": 42,
      "expected_validation": null
    },
    {
      "name": "primitive_integer_rejects_float",
      "type_declarations": [],
      "body_type": "Integer",
      "body": 3.14,
      "expected_validation": {
        "expected_type": "Integer",
        "field_path": "",
        "expected": "Integer",
        "got": "number"
      }
    },
    {
      "name": "primitive_float_accepts_integer_json",
      "type_declarations": [],
      "body_type": "Float",
      "body": 42,
      "expected_validation": null
    },
