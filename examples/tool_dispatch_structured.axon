// AXON Example — Structured Tool Dispatch (§Fase 58)
//
// The canonical shape of the flow-level `use <Tool>(k = v, …)` primitive:
// a multi-field, schema-validated tool call. The tool declares a typed
// input schema (`parameters:`) and an output type (`output_type:`); the
// call binds named args BY NAME, validated against that schema at compile
// time — an unknown/duplicate/missing-required arg or a literal type
// mismatch is CALLER blame (CT-2) BEFORE any dispatch (§58.d). At runtime
// the named args assemble a typed JSON body that is POSTed to the
// tool-server (§58.e/f/f.2), and the typed result binds under
// `CrmRadar_result` for a later step to consume.
//
// Two rules this example encodes:
//   1. Tool dispatch is FLOW-LEVEL. A `use` written inside a `step { }`
//      body is a parse error (§54.a). The legitimate in-step form is
//      `apply: <Tool>` (run the tool as that step's backend).
//   2. Endpoint wiring is config-driven (§58.g): with no absolute
//      `runtime:` URL, the call resolves to {base}/{tool name} where the
//      base is `AXON_TOOL_BASE_URL` (OSS server) or the per-tenant
//      `tool.base_url` config key (enterprise) — the same source runs
//      against any tool-server without edits.

tool CrmRadar {
  provider: http
  parameters: { company: String, max_results: Int, active: Bool }
  output_type: CrmReport
  effects: <network>
  timeout: 10s
}

type CrmRequest {
  company: String
}

type CrmReport {
  summary: String
}

flow ScanCrm(company: String) -> CrmReport {
  // Flow-level structured dispatch: each named arg is checked against
  // CrmRadar.parameters. `company` binds the request parameter; the
  // Int / Bool literals are type-validated at compile time.
  use CrmRadar(company = company, max_results = 5, active = true)

  step Summarize {
    ask: "Summarize the CRM matches for the user"
    output: CrmReport
  }
}

axonendpoint CrmApi {
  method: POST
  path: "/crm/scan"
  body: CrmRequest
  execute: ScanCrm
  // v2.0.0 wire contract: a JSON-transport response is the ψ-vector
  // envelope `FlowEnvelope<T>`, never a bare result type (axon-E039).
  output: FlowEnvelope<CrmReport>
}
