// META: flow_name=DoctrineAnalysisReason, mode=count_only

flow DoctrineAnalysisReason() -> Unit {
    step LoadAuthorities { ask: "Load controlling authorities" output: Stream<Token> }
    reason about_doctrine { target: "precedential_weight" }
    step DraftAnalysis { ask: "Draft doctrinal analysis section" output: Stream<Token> }
}

axonendpoint DoctrineAnalysisReasonEndpoint {
    method: POST
    path: "/legal/doctrine-analysis-reason"
    execute: DoctrineAnalysisReason
    transport: sse
}
